{
  "name": "t3delta",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/justbytes/t3delta.git",
    "directory": "apps/server"
  },
  "bin": {
    "delta": "dist/bin.mjs"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/hermesBin.ts",
    "build": "tsdown",
    "build:bundle": "tsdown",
    "start": "node dist/bin.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:process-reaper": "vitest run src/hermesRelay.test.ts"
  },
  "dependencies": {
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@t3delta/web": "workspace:*",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "^22.16 || ^23.11 || >=24.10"
  }
}
